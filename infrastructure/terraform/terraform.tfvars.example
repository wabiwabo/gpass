# GarudaPass Terraform Variables - Example (Dev Environment)
# Copy this file to terraform.tfvars and adjust values as needed.
# Do NOT commit terraform.tfvars to version control.

# General
aws_region  = "ap-southeast-1"
environment = "dev"
domain_name = "dev.garudapass.id"

# Networking
vpc_cidr           = "10.0.0.0/16"
single_nat_gateway = true # Set to false for HA in production

# EKS
eks_cluster_version     = "1.29"
eks_node_instance_types = ["t3.medium"]
eks_node_min_size       = 2
eks_node_max_size       = 5
eks_node_desired_size   = 2
eks_node_disk_size      = 50

# RDS
db_instance_class          = "db.t3.medium"
db_allocated_storage       = 50
db_max_allocated_storage   = 200
db_engine_version          = "16.2"
db_multi_az                = false
db_backup_retention_period = 7
db_deletion_protection     = false
db_name                    = "garudapass"

# ElastiCache Redis
redis_node_type          = "cache.t3.medium"
redis_num_cache_clusters = 1
redis_engine_version     = "7.1"

# Monitoring
alert_email        = "devops@garudapass.id"
log_retention_days = 14
