{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "title": "GarudaPass — SLO Overview",
  "uid": "gpass-slo-overview",
  "tags": ["garudapass", "slo"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(http_requests_total, service)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {"text": "All", "value": "$__all"}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Availability — last 6h (target 99.9%)",
      "gridPos": {"h": 5, "w": 8, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": 0.995},
              {"color": "green", "value": 0.999}
            ]
          }
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [
        {
          "expr": "1 - service:http_requests:error_ratio_rate6h{service=~\"$service\"}",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error budget burn rate (multi-window)",
      "gridPos": {"h": 9, "w": 16, "x": 8, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}
        }
      },
      "targets": [
        {"expr": "service:http_requests:error_ratio_rate5m{service=~\"$service\"} / 0.001", "legendFormat": "{{service}} — 5m", "refId": "A"},
        {"expr": "service:http_requests:error_ratio_rate1h{service=~\"$service\"} / 0.001", "legendFormat": "{{service}} — 1h", "refId": "B"},
        {"expr": "service:http_requests:error_ratio_rate6h{service=~\"$service\"} / 0.001", "legendFormat": "{{service}} — 6h", "refId": "C"}
      ],
      "thresholds": [
        {"value": 6, "colorMode": "warning", "op": "gt", "fill": false, "line": true, "yaxis": "left"},
        {"value": 14.4, "colorMode": "critical", "op": "gt", "fill": false, "line": true, "yaxis": "left"}
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Request rate by status class",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 9},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"stacking": {"mode": "normal"}}}},
      "targets": [
        {
          "expr": "sum by (class) (rate(http_requests_total{service=~\"$service\"}[5m]))",
          "legendFormat": "{{class}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 9},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (service, le) (rate(http_request_duration_seconds_bucket{service=~\"$service\"}[5m])))", "legendFormat": "p50 {{service}}", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (service, le) (rate(http_request_duration_seconds_bucket{service=~\"$service\"}[5m])))", "legendFormat": "p95 {{service}}", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum by (service, le) (rate(http_request_duration_seconds_bucket{service=~\"$service\"}[5m])))", "legendFormat": "p99 {{service}}", "refId": "C"}
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "DB pool utilization (in_use / open)",
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 17},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}},
      "targets": [
        {
          "expr": "db_pool_in_use{service=~\"$service\"} / db_pool_open_connections{service=~\"$service\"}",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Goroutines",
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 17},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {
          "expr": "go_goroutines{service=~\"$service\"}",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    }
  ]
}
