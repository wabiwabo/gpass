# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=garudapass
KEYCLOAK_CLIENT_ID=bff-client
KEYCLOAK_JWKS_URI=http://localhost:8080/realms/garudapass/protocol/openid-connect/certs

# BFF
BFF_PORT=4000
BFF_ENV=development
BFF_SESSION_SECRET=change-me-to-random-64-chars-minimum-32-characters-required
BFF_COOKIE_DOMAIN=localhost
BFF_REDIRECT_URI=http://localhost:4000/auth/callback
BFF_FRONTEND_URL=http://localhost:3000
BFF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3001

# Redis
REDIS_PASSWORD=garudapass-redis-dev
REDIS_URL=redis://:garudapass-redis-dev@localhost:6379

# PostgreSQL
DATABASE_URL=postgres://garudapass:garudapass@localhost:5432/garudapass?sslmode=disable

# Kafka
KAFKA_BROKERS=localhost:9092

# Kong
KONG_ADMIN_URL=http://localhost:8001

# Identity Service
IDENTITY_PORT=4001
DUKCAPIL_MODE=simulator
DUKCAPIL_URL=http://localhost:4002
DUKCAPIL_API_KEY=
DUKCAPIL_TIMEOUT=10s
SERVER_NIK_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
FIELD_ENCRYPTION_KEY=fedcba9876543210fedcba9876543210fedcba9876543210fedcba9876543210
KEYCLOAK_ADMIN_URL=http://localhost:8080
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin
OTP_REDIS_URL=redis://:garudapass-redis-dev@localhost:6379

# GarudaInfo Service
GARUDAINFO_PORT=4003
GARUDAINFO_DB_URL=postgres://garudapass:garudapass@localhost:5432/garudapass?sslmode=disable
IDENTITY_SERVICE_URL=http://localhost:4001

# Dukcapil Simulator
DUKCAPIL_SIM_PORT=4002

# AHU Simulator
AHU_SIM_PORT=4004

# OSS Simulator
OSS_SIM_PORT=4005

# GarudaCorp Service
GARUDACORP_PORT=4006
AHU_URL=http://localhost:4004
AHU_API_KEY=
AHU_TIMEOUT=10s
OSS_URL=http://localhost:4005
OSS_API_KEY=
OSS_TIMEOUT=10s

# Signing Simulator
SIGNING_SIM_PORT=4008

# GarudaSign Service
GARUDASIGN_PORT=4007
SIGNING_MODE=simulator
SIGNING_SIM_URL=http://localhost:4008
EJBCA_URL=
EJBCA_CLIENT_CERT=
EJBCA_CLIENT_KEY=
DSS_URL=
DOCUMENT_STORAGE_PATH=/data/signing
DOCUMENT_MAX_SIZE_MB=10
SIGNING_REQUEST_TTL=30m
CERT_VALIDITY_DAYS=365
GARUDASIGN_DB_URL=postgres://garudapass:garudapass@localhost:5432/garudapass?sslmode=disable

# GarudaPortal Service
GARUDAPORTAL_PORT=4009
GARUDAPORTAL_DB_URL=postgres://garudapass:garudapass@localhost:5432/garudapass?sslmode=disable

# GarudaAudit Service
GARUDAAUDIT_PORT=4010
GARUDAAUDIT_DB_URL=postgres://garudapass:garudapass@localhost:5432/garudapass?sslmode=disable

# GarudaNotify Service
GARUDANOTIFY_PORT=4011
